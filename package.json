{
  "name": "md2pdf-th",
  "version": "3.1.0",
  "description": "Markdown to PDF library & CLI — Thai/English, dark theme, TOC, cover, merge, watch, NestJS module",
  "keywords": [
    "markdown",
    "pdf",
    "md-to-pdf",
    "thai",
    "cli",
    "converter",
    "pdf-generator",
    "batch",
    "nestjs",
    "puppeteer",
    "pdf-lib"
  ],
  "homepage": "https://github.com/teeprakorn1/md2pdf-th#readme",
  "bugs": {
    "url": "https://github.com/teeprakorn1/md2pdf-th/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teeprakorn1/md2pdf-th.git"
  },
  "license": "MIT",
  "author": "Teepakorn Kumvong",
  "main": "lib/md2pdf-core.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./lib/md2pdf-core.js"
    },
    "./cli": "./md2pdf.js",
    "./nestjs": {
      "types": "./types/nestjs.d.ts",
      "default": "./lib/nestjs/index.js"
    },
    "./nestjs/*": "./lib/nestjs/*.js"
  },
  "bin": {
    "md2pdf-th": "md2pdf.js"
  },
  "files": [
    "md2pdf.js",
    "lib/",
    "types/",
    "style.css",
    "style-dark.css",
    "md2pdf.bat",
    "test/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node md2pdf.js",
    "test": "node test/unit.test.js && node test/md2pdf.test.js",
    "test:unit": "node test/unit.test.js",
    "test:integration": "node test/md2pdf.test.js",
    "prepublishOnly": "npm test"
  },
  "peerDependencies": {
    "@nestjs/common": ">=8.0.0",
    "@nestjs/core": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true }
  },
  "devDependencies": {},
  "dependencies": {
    "md-to-pdf": "^5.2.4",
    "pdf-lib": "^1.17.1",
    "marked": "^15.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
