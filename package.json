    "@nestjs/core": { "optional": true }
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "dependencies": {
    "md-to-pdf": "^5.2.4",
    "pdf-lib": "^1.17.1",
    "marked": "^15.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
