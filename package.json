{
  "name": "md2pdf-th",
  "version": "3.0.0",
  "description": "Markdown to PDF library & CLI — Thai/English, dark theme, TOC, cover, merge, watch, NestJS module",
  "keywords": [
    "markdown",
    "pdf",
    "md-to-pdf",
    "thai",
    "cli",
    "converter",
    "pdf-generator",
    "batch",
    "nestjs",
    "puppeteer",
    "pdf-lib"
  ],
  "homepage": "https://github.com/teeprakorn1/md2pdf-th#readme",
  "bugs": {
    "url": "https://github.com/teeprakorn1/md2pdf-th/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teeprakorn1/md2pdf-th.git"
  },
  "license": "MIT",
  "author": "Teepakorn Kumvong",
  "main": "lib/md2pdf-core.js",
  "exports": {
    ".": "./lib/md2pdf-core.js",
    "./cli": "./md2pdf.js",
    "./nestjs": "./lib/nestjs/index.js",
    "./nestjs/*": "./lib/nestjs/*.js"
  },
  "bin": {
    "md2pdf-th": "md2pdf.js"
  },
  "files": [
